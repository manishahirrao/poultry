{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost:3000",
        "http://localhost:3000/features",
        "http://localhost:3000/pricing",
        "http://localhost:3000/accuracy",
        "http://localhost:3000/solutions/commercial-farms",
        "http://localhost:3000/solutions/integrators",
        "http://localhost:3000/solutions/feed-companies",
        "http://localhost:3000/solutions/enterprise",
        "http://localhost:3000/farm-intelligence",
        "http://localhost:3000/developers",
        "http://localhost:3000/compliance",
        "http://localhost:3000/about",
        "http://localhost:3000/blog",
        "http://localhost:3000/demo",
        "http://localhost:3000/login"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 0,
          "uploadThroughputKbps": 0
        },
        "chromeFlags": "--no-sandbox",
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.97 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "first-contentful-paint": ["error", { "maxNumericValue": 1200 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }],
        "speed-index": ["error", { "maxNumericValue": 3400 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
