      "cell_type": "markdown",
      "metadata": {},
      "source": ["# PoultryPulse AI — Model Inference & Testing\n\nThis notebook loads all PoultryPulse models from Google Drive and runs inference + validation tests.\n\n**Run cells top‑to‑bottom in order.** After the install cell (Cell 2) the runtime will restart automatically — re‑run from Cell 3 onward.\n\n### Prerequisites\nUpload your model files to Google Drive at this path:\n```\nMyDrive/\n├─ ColabNotebooks/\n│   └─ poutrysense_models/\n│       └─ models/\n│           ├─ arima_model.pkl\n│           ├─ prophet_model.pkl\n│           ├─ ridge_meta.pkl\n│           ├─ lightgbm.onnx\n│           ├─ tft_quantized.onnx\n│           └─ calibration_scalars.json\n```"
      ]
    },
    /* ... (all other original cells up to cell 8) ... */
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 12. Live API & Supabase Integration"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# -------------------------------------------------\n",
        "# 1️⃣ Install extra packages (run once)\n",
        "# -------------------------------------------------\n",
        "!pip install supabase-py==2.5.0 httpx --quiet\n",
        "\n",
        "# -------------------------------------------------\n",
        "# 2️⃣ Configuration – replace the placeholders with your real keys\n",
        "# -------------------------------------------------\n",
        "import os\n",
        "LIVE_API_URL   = os.getenv('LIVE_API_URL')   # e.g. 'https://api.example.com/v1/poultry/price'\n",
        "LIVE_API_KEY   = os.getenv('LIVE_API_KEY')   # optional bearer token\n",
        "SUPABASE_URL   = os.getenv('SUPABASE_URL')   # e.g. 'https://xxxx.supabase.co'\n",
        "SUPABASE_ANON_KEY = os.getenv('SUPABASE_ANON_KEY')\n",
        "SUPABASE_TABLE = 'poultry_prices'\n",
        "\n",
        "# -------------------------------------------------\n",
        "# 3️⃣ Helper functions – live API & historical Supabase data\n",
        "# -------------------------------------------------\n",
        "import httpx, pandas as pd\n",
        "from supabase import create_client, Client\n",
        "\n",
        "def fetch_live_price() -> float:\n",
        "    """Fetch the most recent poultry price from the external API.\"""\n",
        "    headers = {}\n",
        "    if LIVE_API_KEY:\n",
        "        headers['Authorization'] = f'Bearer {LIVE_API_KEY}'\n",
        "    try:\n",
        "        resp = httpx.get(LIVE_API_URL, headers=headers, timeout=10.0)\n",
        "        resp.raise_for_status()\n",
        "        data = resp.json()\n",
        "        return float(data['price'])  # adapt key if needed\n",
        "    except Exception as e:\n",
        "        raise RuntimeError(f'Live API request failed: {e}')\n",
        "\n",
        "def fetch_historical_prices(days: int = 30) -> pd.DataFrame:\n",
        "    """Return a DataFrame with columns `date` (datetime) and `price` (float) for the last *days* days.\""\n",
        "    client: Client = create_client(SUPABASE_URL, SUPABASE_ANON_KEY)\n",
        "    start_date = (pd.Timestamp.utcnow() - pd.Timedelta(days=days)).strftime('%Y-%m-%d')\n",
        "    try:\n",
        "        resp = client.table(SUPABASE_TABLE)\n",
        "                    .select('date,price')\n",
        "                    .gte('date', start_date)\n",
        "                    .order('date', desc=False)\n",
        "                    .execute()\n",
        "        if resp.get('error'):\n",
        "            raise RuntimeError(resp['error']['message'])\n",
        "        rows = resp['data']\n",
        "        df = pd.DataFrame(rows)\n",
        "        df['date'] = pd.to_datetime(df['date'])\n",
        "        df['price'] = df['price'].astype(float)\n",
        "        return df\n",
        "    except Exception as e:\n",
        "        raise RuntimeError(f'Supabase query failed: {e}')\n",
        "\n",
        "# -------------------------------------------------\n",
        "# 4️⃣ Build the 45‑feature vector used by the model\n",
        "# -------------------------------------------------\n",
        "import numpy as np\n",
        "\n",
        "def build_feature_vector(live_price: float, hist_df: pd.DataFrame) -> np.ndarray:\n",
        "    """Return a (1, 45) NumPy array matching the model’s expected input shape.\n",
        "    The demo uses three real features (live price, 7‑day mean, 30‑day mean)\n",
        "    and fills the remaining 42 slots with deterministic random numbers.\n",
        "    Replace this with your production feature‑engineering logic.\""\n",
        "    last_7  = hist_df['price'].tail(7).mean()  if len(hist_df) >= 7  else live_price\n",
        "    last_30 = hist_df['price'].tail(30).mean() if len(hist_df) >= 30 else live_price\n",
        "    core = np.array([live_price, last_7, last_30], dtype=np.float32)\n",
        "    np.random.seed(0)  # deterministic filler for the demo\n",
        "    filler = np.random.randn(42).astype(np.float32)\n",
        "    feature_vec = np.concatenate([core, filler])\n",
        "    return feature_vec.reshape(1, -1)  # shape (1, 45)\n",
        "\n",
        "# -------------------------------------------------\n",
        "# 5️⃣ End‑to‑end test run – live + historical data → forecast for tomorrow\n",
        "# -------------------------------------------------\n",
        "service = ModelInferenceService()\n",
        "if not service.load_models():\n",
        "    raise RuntimeError('Model loading failed – check model files in Drive')\n",
        "\n",
        "print('\\n=== Live + Historical Forecast (next day) ===')\n",
        "live_price = fetch_live_price()\n",
        "print(f'Live price today: {live_price:.2f}')\n",
        "historical = fetch_historical_prices(days=30)\n",
        "print(f'Historical rows fetched: {len(historical)}')\n",
        "X_next = build_feature_vector(live_price, historical)\n",
        "result = service.predict(X_next)\n",
        "tomorrow = (pd.Timestamp.utcnow() + pd.Timedelta(days=1)).strftime('%Y-%m-%d')\n",
        "print(f'\\nForecast for {tomorrow}:')\n",
        "print(f'  P10 (10th pct): {result[\'p10\'][0]:.2f}')\",
        "print(f'  P50 (median)  : {result[\'p50\'][0]:.2f}')\",
        "print(f'  P90 (90th pct): {result[\'p90\'][0]:.2f}')\",
        "print(f'  Conformal scalar applied: {result[\'q_hat_applied\']}')\"
      ]
    }
  ]
