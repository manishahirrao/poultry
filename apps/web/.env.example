# PoultryPulse AI - Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# ============================================================================
# SUPABASE CONFIGURATION (ap-south-1 Mumbai — DPDP requirement)
# ============================================================================
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api

# Publicly exposed - safe to use in client-side code (RLS protected)
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon-key]

# Server-only - NEVER in 'use client' files
SUPABASE_SERVICE_ROLE_KEY=[service-key]

# ============================================================================
# TWILIO WHATSAPP BUSINESS API
# ============================================================================
TWILIO_ACCOUNT_SID=[sid]
TWILIO_AUTH_TOKEN=[token]
TWILIO_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# ============================================================================
# WHATSAPP BUSINESS API (Meta)
# ============================================================================
# Used for IoT sensor alerts
WHATSAPP_ACCESS_TOKEN=[whatsapp-access-token]
WHATSAPP_PHONE_NUMBER_ID=[phone-number-id]

# ============================================================================
# MQTT BROKER CONFIGURATION (IoT Sensor Integration)
# ============================================================================
# MQTT broker URL for IoT sensor telemetry
MQTT_BROKER_URL=mqtt://your-broker-url:1883
MQTT_USERNAME=flockiq-worker
MQTT_PASSWORD=your-secure-password

# Or for AWS IoT Core (TLS):
# MQTT_BROKER_URL=mqtts://your-iot-endpoint.amazonaws.com:8883
# MQTT_CERT_PATH=./certs/device.pem.crt
# MQTT_KEY_PATH=./certs/private.pem.key
# MQTT_CA_PATH=./certs/AmazonRootCA1.pem

# ============================================================================
# CRON JOB SECURITY
# ============================================================================
# Secret key for cron job authorization
CRON_SECRET=[cron-secret-key]

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NEXT_PUBLIC_APP_URL=https://poultrypulse.ai
NEXT_PUBLIC_APP_VERSION=0.1.0

# Default language: 'hi' (Hindi) or 'en' (English)
NEXT_PUBLIC_DEFAULT_LANGUAGE=hi

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features during development
NEXT_PUBLIC_ENABLE_ACCURACY_DASHBOARD=true
NEXT_PUBLIC_ENABLE_WHATSAPP_DEMO=true
NEXT_PUBLIC_ENABLE_REFERRAL_PROGRAM=false

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
# Slack webhook for uptime alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Google Analytics 4 (GA4) Measurement ID
# Format: G-XXXXXXXXXX
# Get this from: https://analytics.google.com/ -> Admin -> Data Streams -> Web Stream Details
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# PostHog Analytics
# Get these from your PostHog project settings: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=[your-posthog-project-api-key]
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Monitoring
# Get these from your Sentry project settings: https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=https://[your-sentry-dsn]@sentry.io/[project-id]
SENTRY_AUTH_TOKEN=[your-sentry-auth-token]

# Upstash Redis for rate limiting
# Get these from your Upstash dashboard: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://[your-upstash-redis-url]
UPSTASH_REDIS_REST_TOKEN=[your-upstack-redis-token]

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Set to 'true' to enable debug mode in development
NEXT_PUBLIC_DEBUG=false
